# ── Database ──────────────────────────────────────────────────────
# Uses embedded-postgres by default — no external DB setup needed.
DATABASE_URL=postgresql://lulzasaur:lulzasaur@localhost:5432/lulzasaur

# ── LLM Providers ────────────────────────────────────────────────
# At least one provider is required. Anthropic is recommended.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# HF_TOKEN=hf_...                    # HuggingFace Inference API token
# OLLAMA_BASE_URL=http://localhost:11434

# ── Default LLM ─────────────────────────────────────────────────
# Which provider/model to use when a soul doesn't specify one.
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-5

# ── Web UI ───────────────────────────────────────────────────────
WEB_PORT=3000
WEB_HOST=0.0.0.0

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Heartbeat ────────────────────────────────────────────────────
HEARTBEAT_POLL_INTERVAL_SECONDS=30

# ── Shell Execution ──────────────────────────────────────────────
SHELL_TIMEOUT_MS=30000
SHELL_MAX_OUTPUT_BYTES=1048576

# ── Modules Directory ────────────────────────────────────────────
# Where agent project work is stored. Defaults to ./modules
# MODULES_DIR=/path/to/your/modules

# ── Web Search (optional) ─────────────────────────────────────────
# Tavily API for web search and page extraction.
# Free tier: 1000 searches/month. Sign up at https://tavily.com
# TAVILY_API_KEY=tvly-...

# ── Claude Code (optional) ───────────────────────────────────────
# Path to the Claude Code CLI binary. Defaults to "claude" on PATH.
# Required for the coder agent to delegate coding tasks.
# CLAUDE_BIN=/path/to/claude

# ── Slack Integration (optional) ─────────────────────────────────
# Socket Mode — no public URL or ngrok needed.
# SLACK_BOT_TOKEN=xoxb-...           # Bot User OAuth Token
# SLACK_SIGNING_SECRET=               # From app settings > Basic Information
# SLACK_APP_TOKEN=xapp-...           # App-Level Token (Socket Mode)
# SLACK_ALLOWED_CHANNELS=             # Optional: comma-separated channel IDs
