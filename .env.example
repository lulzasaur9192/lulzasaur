# Database
DATABASE_URL=postgresql://lulzasaur:lulzasaur@localhost:5432/lulzasaur

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434

# Default LLM
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-5-20241022

# Web UI
WEB_PORT=3000
WEB_HOST=0.0.0.0

# Logging
LOG_LEVEL=info

# Heartbeat
HEARTBEAT_POLL_INTERVAL_SECONDS=30

# Shell execution
SHELL_TIMEOUT_MS=30000
SHELL_MAX_OUTPUT_BYTES=1048576
